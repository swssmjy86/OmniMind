NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# P4-4 카카오 AdFit 광고 단위 ID (미설정 시 광고 슬롯 미표시)
NEXT_PUBLIC_ADFIT_UNIT=

# P5 고민/마음 탭 LLM 대화 (openrouter.ai에서 발급 — :free 모델은 무료).
# 미설정 시 자동으로 템플릿(0단계) 응답으로 대체되어 서비스는 계속 동작한다.
OPENROUTER_API_KEY=
# 기본값은 openrouter-provider.ts의 google/gemma-4-26b-a4b-it:free — 다른 무료 모델로
# 바꾸고 싶을 때만 설정. OpenRouter 무료 라인업은 자주 바뀌니 openrouter.ai/models에서
# ":free" 모델을 확인하고, 반드시 ":free" 접미사가 붙은 모델로만 바꿀 것.
OPENROUTER_MODEL=
# P8 상담 크레딧(유료)을 소비하는 상담에만 쓰이는 모델 — OPENROUTER_API_KEY에 실제 결제
# 수단이 연결된 유료 모델을 지정할 것("월 고정비 0원" 원칙과 별개로, 구독 매출로 충당하는
# 변동비). 기본값은 openrouter-provider.ts의 anthropic/claude-3.5-haiku.
OPENROUTER_PREMIUM_MODEL=

# KASI(한국천문연구원) Open API — 절기/일진 대조 스크립트(verify-solar-terms.ts,
# verify-iljin.ts, verify-sky.ts)와 "오늘의 천문현상" 조회(astro-events-cache.ts)에 쓰인다.
# data.go.kr에서 아래 4개 서비스를 개별 활용신청(무료, 자동승인)한 뒤 일반 인증키(Decoding)를
# 채우세요: 음양력 정보, 특일 정보, 출몰시각정보, 태양고도정보, 월령정보, 천문현상정보.
# 미설정 시: verify-*.ts는 실행 불가하고, "오늘의 천문현상" 섹션만 조용히 생략된다
# (월령·출몰시각·태양고도는 astronomy-engine으로 순수 계산되므로 이 키와 무관하게 항상 동작).
KASI_SERVICE_KEY=

# P7-3 결제 (토스페이먼츠) — 개발은 테스트 키(test_ck_/test_sk_)로. P8부터 신규 판매는
# 상담 크레딧 패키지(payment/constants.ts CREDIT_PACKAGES) 방식이며, 이 결제 흐름을 그대로
# 재사용한다.
NEXT_PUBLIC_TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=
# premium_until 갱신 등 서버 전용 쓰기 (Supabase 대시보드 > Settings > API)
SUPABASE_SERVICE_ROLE_KEY=
