NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# P4-4 카카오 AdFit 광고 단위 ID (미설정 시 광고 슬롯 미표시)
NEXT_PUBLIC_ADFIT_UNIT=

# P5 고민/마음 탭 LLM 대화 (openrouter.ai에서 발급 — :free 모델은 무료).
# 미설정 시 자동으로 템플릿(0단계) 응답으로 대체되어 서비스는 계속 동작한다.
OPENROUTER_API_KEY=
# 기본값은 openrouter-provider.ts의 deepseek/deepseek-chat-v3.1:free — 다른 무료 모델로
# 바꾸고 싶을 때만 설정(예: qwen/qwen-2.5-72b-instruct:free).
OPENROUTER_MODEL=

# P7-3 결제 (토스페이먼츠) — 개발은 테스트 키(test_ck_/test_sk_)로.
NEXT_PUBLIC_TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=
# premium_until 갱신 등 서버 전용 쓰기 (Supabase 대시보드 > Settings > API)
SUPABASE_SERVICE_ROLE_KEY=
